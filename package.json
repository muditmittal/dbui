{
  "name": "dbui",
  "private": true,
  "version": "0.2.0",
  "description": "DBUI Design System — Databricks component library built on shadcn/ui with DuBois design tokens",
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    ".": "./packages/dbui/src/index.ts",
    "./components/ui/*": "./packages/dbui/src/components/ui/*.tsx",
    "./components/icons/*": "./packages/dbui/src/components/icons/*.tsx",
    "./components/shells/*": "./packages/dbui-shells/src/components/*.tsx",
    "./lib/*": "./packages/dbui/src/lib/*",
    "./tokens/*": "./packages/dbui/src/tokens/*",
    "./llms.txt": "./packages/dbui/llms.txt"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "tailwindcss": ">=4"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "storybook": "yarn workspace portal storybook"
  },
  "packageManager": "yarn@4.13.0",
  "devDependencies": {
    "@figma/code-connect": "^1.4.2"
  }
}
