{
  "name": "dbui",
  "private": true,
  "version": "0.2.0",
  "description": "DBUI Design System — Databricks component library built on shadcn/ui with DuBois design tokens",
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    ".": "./packages/dbui/src/index.ts",
    "./components/ui/*": "./packages/dbui/src/components/ui/*.tsx",
    "./components/icons/*": "./packages/dbui/src/components/icons/*.tsx",
    "./components/shells/*": "./packages/dbui-shells/src/components/*.tsx",
    "./lib/*": "./packages/dbui/src/lib/*",
    "./tokens/*": "./packages/dbui/src/tokens/*",
    "./llms.txt": "./packages/dbui/llms.txt"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "vaul": "^1.1.2"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "tailwindcss": ">=4"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "yarn workspace portal dev",
    "dev:dbui": "yarn workspace dbui dev",
    "build": "yarn workspace portal build",
    "build:dbui": "yarn workspace dbui build",
    "lint": "yarn workspace portal lint",
    "preview": "concurrently -n portal,storybook -c blue,magenta \"yarn dev\" \"yarn workspace portal storybook\""
  },
  "packageManager": "yarn@4.13.0",
  "engines": {
    "node": "20.x"
  },
  "devDependencies": {
    "@figma/code-connect": "^1.4.2",
    "concurrently": "^9.2.1"
  }
}
