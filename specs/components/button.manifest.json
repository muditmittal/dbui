{
  "$component": "Button",
  "$figmaId": "477:773",
  "$figmaUrl": "https://www.figma.com/design/OftbSQf85jOPln9RhSEhVv?node-id=477-773",
  "$codePath": "packages/dbui/src/lib/button-variants.ts",
  "$storyPath": "apps/portal/src/stories/Button.stories.tsx",
  "guidelines": [
    "Use Primary for the single most important action on a page or dialog",
    "Use Outline as the default for secondary actions alongside Primary",
    "Use Destructive only inside AlertDialog or as a confirmed final action"
  ],
  "constraints": [
    "Link variant: NO icons — only exception is trailing NewWindow for external links",
    "Icon-only buttons (icon-sm/icon-md) MUST have aria-label",
    "Max one Primary button per visible area"
  ],
  "variants": {
    "Variant": {
      "figma": ["Primary", "Outline", "Secondary", "Ghost", "Link", "Destructive", "Danger"],
      "code": ["default", "outline", "secondary", "ghost", "link", "destructive", "danger"],
      "mapping": {
        "Primary": "default",
        "Outline": "outline",
        "Secondary": "secondary",
        "Ghost": "ghost",
        "Link": "link",
        "Destructive": "destructive",
        "Danger": "danger"
      }
    },
    "Size": {
      "figma": ["Default", "Small"],
      "code": ["md", "sm", "icon-md", "icon-sm"],
      "mapping": {
        "Default": "md",
        "Small": "sm"
      }
    },
    "State": {
      "figma": ["Default", "Hover", "Press", "Focus", "Disabled", "Loading"],
      "code": ["default (CSS)", "hover (CSS)", "active (CSS)", "focus-visible (CSS)", "disabled (prop)", "loading (prop)"]
    }
  },
  "innerComponents": {
    ".ActionLabel": {
      "props": {
        "Show Icon": { "code": "<ButtonIcon>", "type": "composition" },
        "Show Menu": { "code": "<ButtonChevron />", "type": "composition" },
        "Label": { "code": "children text", "type": "children" },
        "Icon": { "code": "children of <ButtonIcon>", "type": "instance-swap" },
        "Menu": { "code": "children of <ButtonChevron>", "type": "instance-swap" }
      }
    }
  }
}
