  "tagsAlwaysAllowed": {
    "$comment": "Plain HTML tags that are OK to use anywhere — but the linter will warn if they should be wrapped in a DBUI component.",
    "always": ["html", "body", "head", "title", "meta", "link", "script", "main", "header", "footer", "nav", "section", "article", "aside", "details", "summary"],
    "ok-but-prefer-wrapper": {
      "div": "Consider wrapping content semantics in <Card>, <Field>, <Empty>, <PageHeader>, etc. when applicable.",
      "span": "Use <Label> for label text or <TagLabel>/<KeyValueKey> for inline labels.",
      "p": "Use <FieldDescription> or <CardDescription> for paragraph text inside cards/fields.",
      "h1": "Use <PageHeaderTitle> at the page top, or <DialogTitle>/<AlertDialogTitle>/<DrawerTitle> in overlays.",
      "h2": "Use <CardTitle>, <EmptyTitle>, <DialogTitle>, etc.",
      "h3": "Use <CardTitle>, or section heading with <Label>.",
      "button": "Use <Button>, <IconButton>, <Toggle>, or <SplitButton> from DBUI.",
      "input": "Use <Input>, <Textarea>, or <FormInput>.",
      "select": "Use <Select> or <Combobox> from DBUI.",
      "label": "Use <Label> from DBUI (it's accessible-aware).",
      "img": "Use <AvatarImage> for user images, or <AspectRatio> wrapper for responsive media."
    }
