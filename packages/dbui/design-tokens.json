{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$name": "DBUI Design Tokens",
  "$description": "Databricks DuBois design tokens — shadcn/ui reskinned for Databricks product UI",
  "$version": "1.0.0",

  "color": {
    "surface": {
      "background":           { "$value": "{color.surface.background}", "$type": "color", "$extensions": { "mode": { "light": "#FFFFFF", "dark": "#11171C" } }, "$description": "Primary background" },
      "foreground":           { "$value": "{color.surface.foreground}", "$type": "color", "$extensions": { "mode": { "light": "#161616", "dark": "#E8ECF0" } }, "$description": "Primary text color" },
      "card":                 { "$value": "{color.surface.card}", "$type": "color", "$extensions": { "mode": { "light": "#FFFFFF", "dark": "#11171C" } }, "$description": "Card background" },
      "card-foreground":      { "$value": "{color.surface.card-foreground}", "$type": "color", "$extensions": { "mode": { "light": "#161616", "dark": "#E8ECF0" } } },
      "popover":              { "$value": "{color.surface.popover}", "$type": "color", "$extensions": { "mode": { "light": "#FFFFFF", "dark": "#11171C" } }, "$description": "Popup/dropdown background" },
      "popover-foreground":   { "$value": "{color.surface.popover-foreground}", "$type": "color", "$extensions": { "mode": { "light": "#161616", "dark": "#E8ECF0" } } },
      "secondary":            { "$value": "{color.surface.secondary}", "$type": "color", "$extensions": { "mode": { "light": "#EBEBEB", "dark": "#1F272D" } }, "$description": "Secondary background — slightly visible (neutral100)" },
      "secondary-foreground": { "$value": "{color.surface.secondary-foreground}", "$type": "color", "$extensions": { "mode": { "light": "#161616", "dark": "#E8ECF0" } } },
      "muted":                { "$value": "{color.surface.muted}", "$type": "color", "$extensions": { "mode": { "light": "#F7F7F7", "dark": "#1F272D" } }, "$description": "Subtle background — very light (neutral050)" },
      "muted-foreground":     { "$value": "{color.surface.muted-foreground}", "$type": "color", "$extensions": { "mode": { "light": "#6F6F6F", "dark": "#92A4B3" } }, "$description": "Secondary text, placeholder text" },
      "accent":               { "$value": "{color.surface.accent}", "$type": "color", "$extensions": { "mode": { "light": "#D7EDFE", "dark": "#04355D" } }, "$description": "Accent highlight — blue200, used for menu focus" },
      "accent-foreground":    { "$value": "{color.surface.accent-foreground}", "$type": "color", "$extensions": { "mode": { "light": "#0E538B", "dark": "#4299E0" } } },
      "info":                 { "$value": "{color.surface.info}", "$type": "color", "$extensions": { "mode": { "light": "#F0F8FF", "dark": "rgba(66,153,224,0.16)" } }, "$description": "Alert info background" },
      "success":              { "$value": "{color.surface.success}", "$type": "color", "$extensions": { "mode": { "light": "#F3FCF6", "dark": "rgba(39,124,67,0.16)" } }, "$description": "Alert success background" },
      "warning":              { "$value": "{color.surface.warning}", "$type": "color", "$extensions": { "mode": { "light": "#FFF9EB", "dark": "rgba(190,80,30,0.16)" } }, "$description": "Alert warning background" },
      "danger":               { "$value": "{color.surface.danger}", "$type": "color", "$extensions": { "mode": { "light": "#FFF5F7", "dark": "rgba(200,45,76,0.16)" } }, "$description": "Alert danger background" }
    },

    "action": {
      "primary":               { "$value": "{color.action.primary}", "$type": "color", "$extensions": { "mode": { "light": "#2272B4", "dark": "#4299E0" } }, "$description": "Databricks blue — primary actions" },
      "primary-foreground":    { "$value": "{color.action.primary-foreground}", "$type": "color", "$extensions": { "mode": { "light": "#FFFFFF", "dark": "#11171C" } } },
      "primary-hover":         { "$value": "{color.action.primary-hover}", "$type": "color", "$extensions": { "mode": { "light": "#0E538B", "dark": "#8ACAFF" } }, "$description": "Filled button hover" },
      "primary-press":         { "$value": "{color.action.primary-press}", "$type": "color", "$extensions": { "mode": { "light": "#04355D", "dark": "#BAE1FC" } }, "$description": "Filled button press" },
      "destructive":           { "$value": "{color.action.destructive}", "$type": "color", "$extensions": { "mode": { "light": "#C82D4C", "dark": "#E65B77" } }, "$description": "Destructive/danger actions" },
      "destructive-foreground":{ "$value": "{color.action.destructive-foreground}", "$type": "color", "$extensions": { "mode": { "light": "#FFFFFF", "dark": "#11171C" } } },
      "destructive-hover":     { "$value": "{color.action.destructive-hover}", "$type": "color", "$extensions": { "mode": { "light": "#9E102C", "dark": "#F792A6" } } },
      "destructive-press":     { "$value": "{color.action.destructive-press}", "$type": "color", "$extensions": { "mode": { "light": "#630316", "dark": "#FBD0D8" } } },
      "warning":               { "$value": "{color.action.warning}", "$type": "color", "$extensions": { "mode": { "light": "#BE501E", "dark": "#DE7921" } } },
      "warning-foreground":    { "$value": "{color.action.warning-foreground}", "$type": "color", "$extensions": { "mode": { "light": "#FFFFFF", "dark": "#11171C" } } },
      "success":               { "$value": "{color.action.success}", "$type": "color", "$extensions": { "mode": { "light": "#277C43", "dark": "#3BA65E" } } },
      "success-foreground":    { "$value": "{color.action.success-foreground}", "$type": "color", "$extensions": { "mode": { "light": "#FFFFFF", "dark": "#11171C" } } },
      "ring":                  { "$value": "{color.action.ring}", "$type": "color", "$extensions": { "mode": { "light": "#2272B4", "dark": "#4299E0" } }, "$description": "Focus ring color" },
      "hover":                 { "$value": "{color.action.hover}", "$type": "color", "$extensions": { "mode": { "light": "rgba(34,114,180,0.08)", "dark": "rgba(66,153,224,0.08)" } }, "$description": "Non-filled hover — primary@8%" },
      "press":                 { "$value": "{color.action.press}", "$type": "color", "$extensions": { "mode": { "light": "rgba(34,114,180,0.16)", "dark": "rgba(66,153,224,0.16)" } }, "$description": "Non-filled press — primary@16%" },
      "active":                { "$value": "{color.action.active}", "$type": "color", "$extensions": { "mode": { "light": "#F0F8FF", "dark": "#04355D" } }, "$description": "Selected/active state background — toggle, segment control" },
      "disabled":              { "$value": "{color.action.disabled}", "$type": "color", "$extensions": { "mode": { "light": "#D8D8D8", "dark": "#37444F" } } },
      "disabled-foreground":   { "$value": "{color.action.disabled-foreground}", "$type": "color", "$extensions": { "mode": { "light": "#A2A2A2", "dark": "#5F7281" } } }
    },

    "border": {
      "default":    { "$value": "{color.border.default}", "$type": "color", "$extensions": { "mode": { "light": "#EBEBEB", "dark": "#1F272D" } }, "$description": "Decorative borders, dividers" },
      "input":      { "$value": "{color.border.input}", "$type": "color", "$extensions": { "mode": { "light": "#CBCBCB", "dark": "#37444F" } }, "$description": "Form control borders — darker than decorative" },
      "accessible": { "$value": "{color.border.accessible}", "$type": "color", "$extensions": { "mode": { "light": "#6F6F6F", "dark": "#C0CDD8" } }, "$description": "High-contrast accessible border" }
    },

    "chart": {
      "1": { "$value": "#4299E0", "$type": "color", "$description": "Blue — primary data color" },
      "2": { "$value": "#3BA65E", "$type": "color", "$description": "Green" },
      "3": { "$value": "#DE7921", "$type": "color", "$description": "Orange" },
      "4": { "$value": "#8A63BF", "$type": "color", "$description": "Purple" },
      "5": { "$value": "#C83243", "$type": "color", "$description": "Coral/Red" }
    },

    "utility": {
      "overlay":         { "$value": "{color.utility.overlay}", "$type": "color", "$extensions": { "mode": { "light": "rgba(64,63,63,0.72)", "dark": "rgba(64,63,63,0.85)" } }, "$description": "Modal/dialog backdrop" },
      "code-background": { "$value": "{color.utility.code-background}", "$type": "color", "$extensions": { "mode": { "light": "rgba(82,82,82,0.08)", "dark": "#37444F" } }, "$description": "Inline code background" },
      "skeleton":        { "$value": "{color.utility.skeleton}", "$type": "color", "$extensions": { "mode": { "light": "rgba(162,162,162,0.16)", "dark": "rgba(144,164,181,0.16)" } }, "$description": "Loading skeleton shimmer" }
    },

    "brand": {
      "ai-gradient-start": { "$value": "#4299E0", "$type": "color", "$description": "AI gradient start — blue" },
      "ai-gradient-mid":   { "$value": "#CA42E0", "$type": "color", "$description": "AI gradient mid — purple" },
      "ai-gradient-end":   { "$value": "#FF5F46", "$type": "color", "$description": "AI gradient end — coral" }
    },

    "sidebar": {
      "background":           { "$value": "{color.sidebar.background}", "$type": "color", "$extensions": { "mode": { "light": "#FFFFFF", "dark": "#11171C" } } },
      "foreground":           { "$value": "{color.sidebar.foreground}", "$type": "color", "$extensions": { "mode": { "light": "#161616", "dark": "#E8ECF0" } } },
      "primary":              { "$value": "{color.sidebar.primary}", "$type": "color", "$extensions": { "mode": { "light": "#2272B4", "dark": "#4299E0" } } },
      "primary-foreground":   { "$value": "{color.sidebar.primary-foreground}", "$type": "color", "$extensions": { "mode": { "light": "#FFFFFF", "dark": "#11171C" } } },
      "accent":               { "$value": "{color.sidebar.accent}", "$type": "color", "$extensions": { "mode": { "light": "#F7F7F7", "dark": "#1F272D" } } },
      "accent-foreground":    { "$value": "{color.sidebar.accent-foreground}", "$type": "color", "$extensions": { "mode": { "light": "#161616", "dark": "#E8ECF0" } } },
      "border":               { "$value": "{color.sidebar.border}", "$type": "color", "$extensions": { "mode": { "light": "#EBEBEB", "dark": "#1F272D" } } },
      "ring":                 { "$value": "{color.sidebar.ring}", "$type": "color", "$extensions": { "mode": { "light": "#2272B4", "dark": "#4299E0" } } }
    }
  },

  "radius": {
    "sm":   { "$value": "4px",  "$type": "dimension", "$description": "Buttons, inputs, form controls, menu items" },
    "md":   { "$value": "8px",  "$type": "dimension", "$description": "Dialogs, popups, dropdowns, alerts" },
    "lg":   { "$value": "12px", "$type": "dimension", "$description": "Drawer corners" },
    "xl":   { "$value": "16px", "$type": "dimension", "$description": "Cards" },
    "2xl":  { "$value": "24px", "$type": "dimension", "$description": "Large rounded containers" },
    "3xl":  { "$value": "999px","$type": "dimension", "$description": "Badges, pills, switch, radio, avatar" }
  },

  "spacing": {
    "0":   { "$value": "0px",  "$type": "dimension" },
    "xs":  { "$value": "4px",  "$type": "dimension" },
    "sm":  { "$value": "8px",  "$type": "dimension", "$description": "Base unit" },
    "mid": { "$value": "12px", "$type": "dimension" },
    "md":  { "$value": "16px", "$type": "dimension" },
    "lg":  { "$value": "24px", "$type": "dimension" },
    "xl":  { "$value": "32px", "$type": "dimension" }
  },

  "shadow": {
    "xs":    { "$value": "0 1px 0 0 rgba(0,0,0,0.05)", "$type": "shadow", "$description": "Form controls, bordered buttons" },
    "sm":    { "$value": "0 2px 3px -1px rgba(0,0,0,0.05), 0 1px 0 0 rgba(0,0,0,0.02)", "$type": "shadow", "$description": "Active tabs, elevated elements" },
    "md":    { "$value": "0 3px 6px 0 rgba(0,0,0,0.05)", "$type": "shadow", "$description": "Cards" },
    "lg":    { "$value": "0 2px 16px 0 rgba(0,0,0,0.08)", "$type": "shadow", "$description": "Popovers, dropdowns" },
    "xl":    { "$value": "0 8px 40px 0 rgba(0,0,0,0.13)", "$type": "shadow", "$description": "Dialogs, modals" },
    "focus": { "$value": "0 0 0 1px #FFFFFF, 0 0 0 3px #2272B4", "$type": "shadow", "$description": "Focus indicator for filled controls" }
  },

  "typography": {
    "font-family": {
      "sans":    { "$value": "SF Pro Text, -apple-system, BlinkMacSystemFont, Segoe UI, Roboto, sans-serif", "$type": "fontFamily", "$description": "Body text" },
      "display": { "$value": "SF Pro Display, -apple-system, BlinkMacSystemFont, Segoe UI, Roboto, sans-serif", "$type": "fontFamily", "$description": "Headings" },
      "mono":    { "$value": "SF Mono, SFMono-Regular, ui-monospace, Cascadia Code, Fira Code, monospace", "$type": "fontFamily", "$description": "Code" }
    },
    "styles": {
      "hint":      { "$value": { "fontFamily": "{typography.font-family.sans}", "fontSize": "12px", "lineHeight": "16px", "fontWeight": 400 }, "$type": "typography", "$description": "Captions, helper text" },
      "paragraph": { "$value": { "fontFamily": "{typography.font-family.sans}", "fontSize": "13px", "lineHeight": "20px", "fontWeight": 400 }, "$type": "typography", "$description": "Body text — the base style" },
      "bold":      { "$value": { "fontFamily": "{typography.font-family.sans}", "fontSize": "13px", "lineHeight": "20px", "fontWeight": 600 }, "$type": "typography", "$description": "Labels, emphasis" },
      "code":      { "$value": { "fontFamily": "{typography.font-family.mono}", "fontSize": "13px", "lineHeight": "20px", "fontWeight": 400 }, "$type": "typography", "$description": "Code snippets" },
      "title-4":   { "$value": { "fontFamily": "{typography.font-family.display}", "fontSize": "13px", "lineHeight": "20px", "fontWeight": 600 }, "$type": "typography", "$description": "Small headings" },
      "title-3":   { "$value": { "fontFamily": "{typography.font-family.display}", "fontSize": "18px", "lineHeight": "24px", "fontWeight": 600 }, "$type": "typography", "$description": "Section headings" },
      "title-2":   { "$value": { "fontFamily": "{typography.font-family.display}", "fontSize": "22px", "lineHeight": "28px", "fontWeight": 600 }, "$type": "typography", "$description": "Page headings" },
      "title-1":   { "$value": { "fontFamily": "{typography.font-family.display}", "fontSize": "32px", "lineHeight": "40px", "fontWeight": 600 }, "$type": "typography", "$description": "Large headings" }
    }
  }
}
